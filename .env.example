PORT=3000

# Chat model selection
# Supported values: anthropic, openai
MODEL_PROVIDER=anthropic

# Chat model names depend on the selected provider.
# Anthropic example: claude-haiku-4-5-20251001
# OpenAI example: gpt-4o-mini
MODEL_NAME=claude-haiku-4-5-20251001

# Required when MODEL_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Required when MODEL_PROVIDER=openai
# Also required when EMBEDDING_PROVIDER=openai.
OPENAI_API_KEY=

# Required for the web_search tool
TAVILY_API_KEY=

# Local RAG corpus settings
# Supported values: local, openai
# Use local if you want the app to work with only an Anthropic API key.
EMBEDDING_PROVIDER=local
RAG_DOCS_DIR=docs
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
